#!/bin/sh
set -eu

addr="${1:-${COACT_NVIM_LISTEN_ADDRESS:-${NVIM:-}}}"
nonce="${2:-${COACT_NVIM_HOOK_NONCE:-}}"
nvim_bin="${3:-${COACT_NVIM_BIN:-nvim}}"
debug_log="${4:-${COACT_NVIM_APPLY_PATCH_DEBUG_LOG:-}}"

debug() {
  if [ -z "$debug_log" ]; then
    return 0
  fi
  printf '%s shell pid=%s %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$$" "$*" >> "$debug_log" 2>/dev/null || true
}

json_escape() {
  printf "%s" "$1" | tr '\n\r' '  ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

deny() {
  reason="$(json_escape "$1")"
  debug "deny reason=$reason"
  printf '%s\n' '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"'"$reason"'"}}'
}

debug "start addr=$addr nvim_bin=$nvim_bin nonce_len=${#nonce} debug_log=$debug_log"

if [ -z "$addr" ]; then
  deny "coact.nvim apply_patch hook is not connected to a Neovim RPC server"
  exit 0
fi

tmpdir="${TMPDIR:-/tmp}"
tmpdir="${tmpdir%/}"
if [ -z "$tmpdir" ]; then
  tmpdir="/tmp"
fi

payload="$(mktemp "$tmpdir/coact-nvim-apply-patch.XXXXXX")"
stderr="$(mktemp "$tmpdir/coact-nvim-apply-patch-stderr.XXXXXX")"
result="$(mktemp "$tmpdir/coact-nvim-apply-patch-result.XXXXXX")"
rm -f "$result"
trap 'rm -f "$payload" "$stderr" "$result"' EXIT
cat > "$payload"
payload_bytes="$(wc -c < "$payload" 2>/dev/null || printf 'unknown')"
debug "payload_written path=$payload bytes=$payload_bytes"

lua_escape() {
  printf "%s" "$1" | sed "s/\\\\/\\\\\\\\/g; s/'/\\\\'/g"
}

payload_lua="$(lua_escape "$payload")"
nonce_lua="$(lua_escape "$nonce")"
result_lua="$(lua_escape "$result")"
expr="luaeval('require(\"coact.native_apply_patch_hook\").review_file_async(_A)', {'payload': '$payload_lua', 'nonce': '$nonce_lua', 'result': '$result_lua'})"
debug "remote_expr_ready payload=$payload result=$result"

if ! output="$("$nvim_bin" --server "$addr" --remote-expr "$expr" < /dev/null 2>"$stderr")"; then
  err="$(cat "$stderr" 2>/dev/null || true)"
  debug "remote_expr_failed stderr=$err"
  if [ -n "$err" ]; then
    deny "coact.nvim apply_patch hook failed to reach the target Neovim RPC server: $err"
  else
    deny "coact.nvim apply_patch hook failed to reach the target Neovim RPC server"
  fi
  exit 0
fi

debug "remote_expr_ok output=$output"

timeout_sec="${COACT_NVIM_APPLY_PATCH_TIMEOUT:-600}"
case "$timeout_sec" in
  *[!0-9]*|"") timeout_sec=600 ;;
esac
limit=$((timeout_sec * 10))
count=0
while [ "$count" -lt "$limit" ]; do
  if [ -s "$result" ]; then
    debug "result_ready path=$result"
    cat "$result"
    printf '\n'
    exit 0
  fi
  count=$((count + 1))
  sleep 0.1
done

deny "Timed out waiting for Neovim apply_patch review."
